# Archil disk (control plane + S3-style object ops over HTTPS)
ARCHIL_API_KEY=key-xxxxxxxx          # account API key (NOT a disk/mount adt_ token)
ARCHIL_REGION=aws-us-east-1
ARCHIL_DISK=youraccount/your-disk    # account/disk name; resolved to a dsk-… id at runtime

# Model auth for the extracted Claude Code bundle (no keychain on Vercel)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# or, instead of an API key, a long-lived OAuth token from `claude setup-token`:
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: workspace root inside the sandbox fs (default /workspace)
# CC_WORKSPACE=/workspace

# --- Auth: Better Auth + GitHub OAuth (gates the whole app) ---
# Session/crypto secret, min 32 chars. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public origin of THIS deployment, no trailing slash. Must match the GitHub
# OAuth callback. Dev: http://localhost:3000 — set the prod URL for prod deploys.
BETTER_AUTH_URL=http://localhost:3000
# GitHub OAuth app — create at https://github.com/settings/developers
#   Homepage URL:               <BETTER_AUTH_URL>
#   Authorization callback URL: <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# PlanetScale Postgres connection string. Use the PgBouncer endpoint (port 6432)
# for serverless pooling, and require TLS. Example:
#   postgresql://USER:PASSWORD@HOST.horizon.psdb.cloud:6432/postgres?sslmode=verify-full
DATABASE_URL=
