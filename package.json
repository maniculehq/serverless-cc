{
  "name": "serverless-cc",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "fetch-cli": "bun scripts/fetch-cli.mjs",
    "dev": "bun scripts/fetch-cli.mjs && next dev",
    "build": "bun scripts/fetch-cli.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "local": "bun scripts/fetch-cli.mjs && bun run --env-file=.env local.mjs",
    "test:workers": "bun scripts/fetch-cli.mjs && bun run --env-file=.env scripts/test-workers.mjs",
    "deploy": "bash deploy.sh",
    "deploy:prod": "bash deploy.sh --prod"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.177",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "ai": "^6.0.205",
    "better-auth": "^1.6.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "disk": "0.8.13",
    "just-bash": "3.0.1",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
